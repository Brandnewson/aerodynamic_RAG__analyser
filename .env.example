# Application
APP_NAME="AeroInsight API"
APP_VERSION="0.1.0"
DEBUG=false

# Database — SQLite file path (relative to project root)
DATABASE_URL="sqlite:///./database.db"

# ChromaDB — directory for persistent vector storage
CHROMA_PERSIST_DIR="./chroma_db"
CHROMA_COLLECTION_NAME="aero_literature"

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# RAG retrieval
RETRIEVAL_TOP_K=5
